# Database settings used by docker-compose.yml
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=tuffyplan
MYSQL_USER=tuffyuser
MYSQL_PASSWORD=tuffypass

# Backend Firebase settings
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=csuf-course-recommendation-sys.firebaseapp.com
FIREBASE_PROJECT_ID=csuf-course-recommendation-sys
FIREBASE_STORAGE_BUCKET=csuf-course-recommendation-sys.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Frontend runtime settings
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
